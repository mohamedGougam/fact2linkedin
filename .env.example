# Copy this file to `.env.local` and adjust values locally.
# `.env.local` is gitignored — do not commit real secrets.

# -----------------------------------------------------------------------------
# Research (facts)
# -----------------------------------------------------------------------------
# mock = offline templates (default, no API keys)
# web  = live search when SEARCH_API_URL + SEARCH_API_KEY are set; otherwise mock
RESEARCH_PROVIDER=mock

# Brave Web Search example — get a key at https://brave.com/search/api/
# SEARCH_API_URL=https://api.search.brave.com/res/v1/web/search
# SEARCH_API_KEY=

SEARCH_API_URL=
SEARCH_API_KEY=

# -----------------------------------------------------------------------------
# Post generation (KAWN Post drafts)
# -----------------------------------------------------------------------------
# template = deterministic strings (default, no OpenAI)
# ai       = use AI provider when OPENAI_API_KEY is set (placeholder until implemented)
POST_GENERATION_PROVIDER=template

# -----------------------------------------------------------------------------
# OpenAI (optional — AI improve on each post)
# -----------------------------------------------------------------------------
# When set, “AI improve” calls the Chat Completions API to rewrite an existing draft
# using only the selected facts. Template generation does not require this.
OPENAI_API_KEY=

# Optional model override (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o-mini
